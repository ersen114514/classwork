# a def to check number is correct.
def true_number(prompt="请输入您的数字: "):
    while True:  # 无限循环，直到获得有效输入
        user_input = input(prompt)
        # 尝试将输入转换为浮点数
        try:
            true_number = float(user_input)
        except ValueError:
            # 输入无法转换为数字
            print(f"error：'{user_input}'isn't a number ")
        return true_number

mark=true_number("please put your number")
# a def to get letter grade
def letter_grade(mark):
    if mark<0 or mark >100:
        print ("your number must greater than 0 and smaller than 100")
    elif mark>=90:
        grade='A'
    elif mark>=80 and mark<90:
        grade='B'
    elif mark>=70 and mark<80:
        grade='C'
    elif mark>=60 and mark<70:
        grade='D'
    else:
        grade='F'
        return grade

level=letter_grade(mark)
#output 
print(f"{mark} point is level {level}")
